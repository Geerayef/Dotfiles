adjust-cell-height = 100%
adjust-underline-position = 10%
background = #010204
background-opacity = 1
cursor-color = #FFF779
cursor-style = block
cursor-style-blink = false
cursor-text = #010204
font-family = Iosevka
font-family = IosevkaTerm NFM
font-family-bold = Iosevka Bold
font-family-bold-italic = Iosevka Bold Italic
font-family-italic = Iosevka Italic
font-size = 12
font-synthetic-style = false
gtk-custom-css = ./ghostty.css
gtk-tabs-location = bottom
maximize = true
shell-integration-features = no-cursor
theme = Batman
window-decoration = none
window-padding-balance = false
window-padding-color = background
window-padding-x = 0
window-padding-y = 0
window-theme = dark
keybind = ctrl+q>t=new_tab
keybind = ctrl+q>n=next_tab
keybind = ctrl+q>p=previous_tab
keybind = ctrl+q>1=goto_tab:1
keybind = ctrl+q>2=goto_tab:2
keybind = ctrl+q>3=goto_tab:3
keybind = ctrl+q>4=goto_tab:4
keybind = ctrl+q>5=goto_tab:5
keybind = ctrl+q>6=goto_tab:6
keybind = ctrl+q>7=goto_tab:7
keybind = ctrl+q>8=goto_tab:8
keybind = ctrl+q>9=goto_tab:9
keybind = ctrl+q>v=new_split:right
keybind = ctrl+q>s=new_split:down
keybind = ctrl+q>h=goto_split:left
keybind = ctrl+q>j=goto_split:down
keybind = ctrl+q>k=goto_split:up
keybind = ctrl+q>l=goto_split:right
