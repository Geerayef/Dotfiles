{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "completion": {
    "enable": true,
    "autoRequire": true,
    "callSnippet": true,
    "postfix": "@"
  },
  "runtime": {
    "version": "LuaJIT",
    "requirePattern": [
      "?.lua",
      "?/init.lua",
      "?/lua/?.lua",
      "?/lua/?/init.lua",
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "workspace": { "library": ["/usr/share/hypr/stubs/"] }
}
