{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "pathStrict": true,
    "path": [
      "?.lua",
      "?/init.lua",
      "?/lua/?.lua",
      "?/lua/?/init.lua",
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "workspace": {
    "maxPreload": 1600,
    "preloadFileSize": 1000,
    "ignoreDir": ["/.vscode"],
    "checkThirdParty": false,
    "library": [
      "/usr/share/nvim/runtime",
      "/home/tib/.local/share/nvim/lazy",
      "/home/tib/.config/nvim",
      "$VIMRUNTIME",
      "$XDG_DATA_HOME/nvim/lazy",
      "$XDG_CONFIG_HOME/nvim"
    ]
  },
  "typeFormat": { "config": { "format_line": "true" } },
  "type": { "castNumberToInteger": true }
}
